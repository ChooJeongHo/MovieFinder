<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/detail_backdrop_height"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fitsSystemWindows="true"
            app:contentScrim="?attr/colorSurface"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:expandedTitleTextColor="@android:color/transparent">

            <ImageView
                android:id="@+id/iv_backdrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/cd_movie_backdrop"
                android:fitsSystemWindows="true"
                android:scaleType="centerCrop"
                app:layout_collapseMode="parallax" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/backdrop_overlay"
                android:importantForAccessibility="no" />

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:navigationIcon="@drawable/ic_arrow_back"
                app:navigationContentDescription="@string/cd_navigate_back" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <include
        android:id="@+id/shimmerDetail"
        layout="@layout/layout_shimmer_detail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/content_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md"
            android:visibility="gone">

            <!-- 제목 -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceHeadline5"
                android:textStyle="bold"
                tools:text="영화 제목" />

            <!-- 태그라인 -->
            <TextView
                android:id="@+id/tv_tagline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:alpha="0.7"
                android:fontFamily="sans-serif-light"
                android:textAppearance="?attr/textAppearanceBody1"
                android:textStyle="italic"
                android:visibility="gone"
                tools:text="태그라인" />

            <!-- 평점 + 정보 행 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.choo.moviefinder.presentation.common.CircularRatingView
                    android:id="@+id/rating_view"
                    android:layout_width="@dimen/rating_view_size_large"
                    android:layout_height="@dimen/rating_view_size_large"
                    android:importantForAccessibility="yes" />

                <TextView
                    android:id="@+id/tv_release_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:textAppearance="?attr/textAppearanceBody2"
                    tools:text="개봉일: 2024-01-01" />

                <TextView
                    android:id="@+id/tv_runtime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:textAppearance="?attr/textAppearanceBody2"
                    tools:text="120분" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_certification"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:clickable="false"
                    android:checkable="false"
                    android:visibility="gone"
                    tools:text="15" />

            </LinearLayout>

            <!-- 장르 -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_genres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md" />

            <!-- 내 평점 -->
            <TextView
                android:id="@+id/tv_my_rating_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/my_rating_title"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/my_rating_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <RatingBar
                    android:id="@+id/rating_bar_user"
                    style="?android:attr/ratingBarStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/my_rating_title"
                    android:numStars="5"
                    android:stepSize="0.5"
                    android:rating="0"
                    android:isIndicator="false" />

                <ImageButton
                    android:id="@+id/btn_clear_rating"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="@dimen/spacing_xxs"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/clear_rating"
                    android:padding="12dp"
                    android:src="@drawable/ic_close"
                    android:visibility="gone"
                    app:tint="@color/icon_default" />

            </LinearLayout>

            <!-- 예고편 버튼 (fallback) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_trailer"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="@string/play_trailer"
                android:visibility="gone"
                app:icon="@drawable/ic_play" />

            <!-- 시리즈 보기 버튼 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_view_collection"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/collection_view_series"
                android:visibility="gone" />

            <!-- 예고편 인앱 재생 -->
            <com.pierfrancescosoffritti.androidyoutubeplayer.core.player.views.YouTubePlayerView
                android:id="@+id/youtube_player_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:visibility="gone"
                app:autoPlay="false"
                app:showFullScreenButton="true" />

            <!-- 줄거리 -->
            <TextView
                android:id="@+id/tv_overview_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/overview_title"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_overview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:lineSpacingMultiplier="1.3"
                android:textAppearance="?attr/textAppearanceBody1"
                tools:text="줄거리 내용..." />

            <!-- 출연진 -->
            <TextView
                android:id="@+id/tv_cast_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/cast_title"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:textStyle="bold"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_cast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                android:visibility="gone" />

            <!-- 비슷한 영화 -->
            <TextView
                android:id="@+id/tv_similar_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/similar_movies_title"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:textStyle="bold"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_similar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                android:visibility="gone" />

            <!-- 추천 영화 -->
            <TextView
                android:id="@+id/tv_recommendations_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/recommendations_title"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:textStyle="bold"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recommendations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                android:visibility="gone" />

            <!-- 리뷰 -->
            <TextView
                android:id="@+id/tv_reviews_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/reviews_label"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:textStyle="bold"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_reviews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:visibility="gone" />

            <!-- 메모 -->
            <TextView
                android:id="@+id/tv_memo_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/memo_title"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_memo"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:hint="@string/memo_hint"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_send"
                app:endIconContentDescription="@string/memo_save">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_memo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:maxLines="4" />

            </com.google.android.material.textfield.TextInputLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_memos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

            <!-- 영화 정보 (확장) -->
            <TextView
                android:id="@+id/tv_movie_info_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/movie_info_title"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:textStyle="bold"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/movie_info_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_xs"
                    android:textAppearance="?attr/textAppearanceBody2"
                    tools:text="상태: Released" />

                <TextView
                    android:id="@+id/tv_original_language"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_xs"
                    android:textAppearance="?attr/textAppearanceBody2"
                    tools:text="원어: en" />

                <TextView
                    android:id="@+id/tv_budget"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_xs"
                    android:textAppearance="?attr/textAppearanceBody2"
                    android:visibility="gone"
                    tools:text="제작비: $150,000,000" />

                <TextView
                    android:id="@+id/tv_revenue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_xs"
                    android:textAppearance="?attr/textAppearanceBody2"
                    android:visibility="gone"
                    tools:text="수익: $500,000,000" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_imdb"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/imdb_link"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- 등급 배지 위치를 위한 여백 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/spacing_xl" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- 에러 -->
    <include
        android:id="@+id/error_view"
        layout="@layout/layout_error"
        android:visibility="gone" />

    <!-- 워치리스트 FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_watchlist"
        style="@style/Widget.MaterialComponents.FloatingActionButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/detail_watchlist_fab_bottom_margin"
        android:contentDescription="@string/cd_watchlist"
        android:src="@drawable/ic_watchlist"
        app:backgroundTint="?attr/colorSurface"
        app:fabSize="mini"
        app:tint="?attr/colorOnSurface"
        app:layout_anchor="@id/nested_scroll"
        app:layout_anchorGravity="bottom|end"
        android:visibility="gone" />

    <!-- 즐겨찾기 FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_favorite"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/detail_fab_margin"
        android:contentDescription="@string/cd_favorite"
        android:src="@drawable/ic_favorite_border"
        app:tint="?attr/colorOnPrimary"
        app:layout_anchor="@id/nested_scroll"
        app:layout_anchorGravity="bottom|end" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
